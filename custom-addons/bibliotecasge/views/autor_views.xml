<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Vista de lista (tree) -->
    <record id="view_biblioteca_autor_tree" model="ir.ui.view">
        <field name="name">biblioteca.autor.tree</field>
        <field name="model">bibliotecasge.autor</field>
        <field name="arch" type="xml">
            <tree string="Autores">
                <field name="name"/>
                <field name="nacionalidad"/>
                <field name="fecha_nacimiento"/>
            </tree>
        </field>
    </record>

    <!-- Vista de formulario -->
    <record id="view_biblioteca_autor_form" model="ir.ui.view">
        <field name="name">biblioteca.autor.form</field>
        <field name="model">bibliotecasge.autor</field>
        <field name="arch" type="xml">
            <form string="Autor">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="nacionalidad"/>
                        </group>
                        <group>
                            <field name="fecha_nacimiento"/>
                        </group>
                    </group>
                    <!-- Mostrar los libros del autor -->
                    <notebook>
                        <page string="Libros escritos">
                            <field name="libro_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="isbn"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_biblioteca_autor" model="ir.actions.act_window">
        <field name="name">Autores</field>
        <field name="res_model">bibliotecasge.autor</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_biblioteca_autores"
              name="Autores"
              parent="menu_biblioteca_root"
              action="action_biblioteca_autor"
              sequence="10"/>

</odoo>