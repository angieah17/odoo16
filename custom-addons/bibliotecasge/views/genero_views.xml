<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Vista de lista (tree) -->
    <record id="view_biblioteca_genero_tree" model="ir.ui.view">
        <field name="name">biblioteca.genero.tree</field>
        <field name="model">bibliotecasge.genero</field>
        <field name="arch" type="xml">
            <tree string="Géneros literarios">
                <field name="name"/>
                <field name="descripcion"/>
            </tree>
        </field>
    </record>

    <!-- Vista de formulario -->
    <record id="view_biblioteca_genero_form" model="ir.ui.view">
        <field name="name">biblioteca.genero.form</field>
        <field name="model">bibliotecasge.genero</field>
        <field name="arch" type="xml">
            <form string="Género">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="descripcion"/>
                    </group>
                    <!-- Mostrar libros de este género -->
                    <notebook>
                        <page string="Libros de este género">
                            <field name="libro_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="autor_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_biblioteca_genero" model="ir.actions.act_window">
        <field name="name">Géneros</field>
        <field name="res_model">bibliotecasge.genero</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_biblioteca_generos"
              name="Géneros"
              parent="menu_biblioteca_root"
              action="action_biblioteca_genero"
              sequence="20"/>

</odoo>