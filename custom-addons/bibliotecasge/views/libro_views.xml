<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Vista de lista -->
    <record id="view_biblioteca_libro_tree" model="ir.ui.view">
        <field name="name">biblioteca.libro.tree</field>
        <field name="model">bibliotecasge.libro</field>
        <field name="arch" type="xml">
            <tree string="Libros">
                <field name="name"/>
                <field name="autor_id"/> <!-- NUEVO -->
                <field name="isbn"/>
                <field name="state"/>
                <field name="genero_ids" widget="many2many_tags"/> <!-- NUEVO -->
            </tree>
        </field>
    </record>

    <!-- Vista de formulario -->
    <record id="view_biblioteca_libro_form" model="ir.ui.view">
        <field name="name">biblioteca.libro.form</field>
        <field name="model">bibliotecasge.libro</field>
        <field name="arch" type="xml">
            <form string="Libro">
                <sheet>
                    <group>
                        <group string="Información básica">
                            <field name="name"/>
                            <field name="isbn"/>
                            <field name="state"/>
                        </group>
                        <group string="Clasificación">
                            <field name="autor_id"/> <!-- NUEVO -->
                            <field name="genero_ids" widget="many2many_tags"/> <!-- NUEVO -->
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_biblioteca_libro" model="ir.actions.act_window">
        <field name="name">Libros</field>
        <field name="res_model">bibliotecasge.libro</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menú raíz (solo una vez) -->
    <menuitem id="menu_biblioteca_root" name="Biblioteca Escolar"/>

    <!-- Submenú de libros -->
    <menuitem id="menu_biblioteca_libros"
              name="Libros"
              parent="menu_biblioteca_root"
              action="action_biblioteca_libro"
              sequence="30"/>

</odoo>